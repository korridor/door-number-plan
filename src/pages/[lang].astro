---
import App from '../components/App.vue';
import '../styles/global.css';
import type { Locale } from '../lib/types';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'de' } },
  ];
}

const locale = Astro.params.lang as Locale;
const metadata = {
  en: {
    title: 'Door Number Plan — Free Building Directory Generator',
    description: 'Create a printable door number and floor directory for apartment buildings. Free, private and entirely in your browser.',
  },
  de: {
    title: 'Türnummernplan — Kostenloser Gebäudeplan-Generator',
    description: 'Erstelle einen druckbaren Türnummern- und Stockwerksplan für Wohngebäude. Kostenlos, privat und direkt im Browser.',
  },
}[locale];
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={metadata.description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{metadata.title}</title>
  </head>
  <body>
    <App locale={locale} client:load />
  </body>
</html>
